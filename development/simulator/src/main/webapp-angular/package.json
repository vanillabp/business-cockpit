{
  "name": "webapp-angular",
  "version": "0.1.1-SNAPSHOT",
  "scripts": {
    "ng": "ng",
    "prettier": "prettier --write \"**/*.{js,json,css,scss,less,md,ts,html,component.html}\"",
    "start": "ng serve webapp",
    "build": "ng build library -c production && ng build library-web-components -c production && webpack && echo '/* eslint-disable */' | cat - dist/bundle.js > dist/tmp && mv dist/tmp ../../../target/classes/static/TestModule/remoteEntry.js",
    "watch": "ng build --watch --configuration development",
    "publish:snapshot": "echo 'no publish for webapps'",
    "unpublish:snapshot": "echo 'no unpublish for webapps'",
    "test": "ng test",
    "version:snapshot": "npm version ${npm_config_newversion} --no-git-tag-version",
    "publish:release": "echo 'no publish for webapps'"
  },
  "private": true,
  "dependencies": {
    "@vanillabp/bc-types": "0.1.1-SNAPSHOT.14",
    "@vanillabp/bc-official-gui-client": "0.1.1-SNAPSHOT.14",
    "@vanillabp/bc-dev-shell-angular": "0.1.1-SNAPSHOT.16",
    "@angular/animations": "20.3.16",
    "@angular/common": "20.3.16",
    "@angular/compiler": "20.3.16",
    "@angular/core": "20.3.16",
    "@angular/elements": "20.3.16",
    "@angular/forms": "20.3.16",
    "@angular/platform-browser": "20.3.16",
    "@angular/platform-browser-dynamic": "20.3.16",
    "@angular/router": "20.3.16",
    "primeng": "20.4.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@angular/build": "20.3.15",
    "@angular/cli": "20.3.15",
    "@angular/compiler-cli": "20.3.16",
    "@schuchard/prettier": "^5.1.0",
    "@types/jasmine": "~5.1.0",
    "css-loader": "^6.10.0",
    "husky": "latest",
    "jasmine-core": "~5.1.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "lint-staged": "latest",
    "ng-packagr": "20.3.2",
    "prettier": "latest",
    "style-loader": "^3.3.4",
    "tslint-config-prettier": "latest",
    "typescript": "5.9.3",
    "webpack-cli": "^5.1.4"
  }
}
