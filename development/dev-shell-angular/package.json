{
  "name": "@vanillabp/bc-dev-shell-angular-module",
  "version": "0.1.1-SNAPSHOT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vanillabp/business-cockpit.git"
  },
  "homepage": "https://github.com/vanillabp/business-cockpit",
  "scripts": {
    "ng": "ng",
    "build": "ng build dev-shell",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "unpublish:snapshot": "npm run unpublish:dev-shell && npm run unpublish:module",
    "unpublish:module": "npm view --registry=\"${NPM_REGISTRY}\" > /dev/null 2>&1 && npm unpublish --registry=\"${NPM_REGISTRY}\" --force || echo \"Package not present – skipping unpublish\"",
    "publish:snapshot": "cd dist/dev-shell && npm publish --tag snapshot",
    "unpublish:dev-shell": "cd dist/dev-shell && npm view --registry=\"${NPM_REGISTRY}\" > /dev/null 2>&1 && npm unpublish --registry=\"${NPM_REGISTRY}\" --force || echo \"Package not present – skipping unpublish\"",
    "version:snapshot": "cd dist/dev-shell && npm version ${npm_config_newversion} --no-git-tag-version",
    "publish:release": "cd dist/dev-shell && npm publish --access public"
  },
  "devDependencies": {
    "@angular/build": "21.1.1",
    "@angular/cli": "21.1.1",
    "@angular/common": "21.1.1",
    "@angular/compiler": "21.1.1",
    "@angular/compiler-cli": "21.1.1",
    "@angular/core": "21.1.1",
    "@angular/forms": "21.1.1",
    "@angular/platform-browser": "21.1.1",
    "@angular/router": "21.1.1",
    "@types/jasmine": "~5.1.0",
    "@vanillabp/bc-official-gui-client": ">=0.1.1-SNAPSHOT <0.1.2",
    "@vanillabp/bc-types": ">=0.1.1-SNAPSHOT <0.1.2",
    "jasmine-core": "~5.1.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "ng-packagr": "21.1.0",
    "primeng": "21.0.4",
    "rxjs": "7.8.2",
    "typescript": "5.9.3",
    "zone.js": "~0.15.1"
  }
}
