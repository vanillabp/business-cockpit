{
  "name": "@vanillabp/bc-dev-shell-vue",
  "version": "0.1.2-SNAPSHOT.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "unpublish:snapshot": "npm view --registry=\"${NPM_REGISTRY}\" > /dev/null 2>&1 && npm unpublish --registry=\"${NPM_REGISTRY}\" --force || echo \"Package not present – skipping unpublish\"",
    "publish:snapshot": "npm publish --tag snapshot",
    "version:snapshot": "npm version ${npm_config_newversion} --no-git-tag-version",
    "publish:release": "npm publish --access public"
  },
  "peerDependencies": {
    "@vanillabp/bc-official-gui-client": ">=0.1.2-SNAPSHOT <0.1.3",
    "@vanillabp/bc-types": ">=0.1.2-SNAPSHOT <0.1.3",
    "primevue": "^4.3.0",
    "@primevue/themes": "^4.3.0",
    "vue": "^3.5.0",
    "vue-router": "^4.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "primevue": "^4.3.0",
    "typescript": "~5.6.3",
    "vite": "^6.0.0",
    "vite-plugin-css-injected-by-js": "^3.5.2",
    "vite-plugin-dts": "^4.0.0",
    "vue": "^3.5.26",
    "vue-router": "^4.5.0",
    "vue-tsc": "^2.2.0"
  }
}
